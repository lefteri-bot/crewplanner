:root{
  --bg:#0b1220;
  --card:#111a2e;
  --muted:#8ea2c6;
  --text:#e7eefc;
  --line:#243152;
  --btn:#1f2d4f;
  --btn2:#2a3d6c;
  --danger:#ff4d4d;
  --warn:#ffd24d;
  --ok:#3ee28a;
  --white:#f6f7fb;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial;
  background: radial-gradient(1200px 800px at 20% 10%, #162447 0%, var(--bg) 70%);
  color:var(--text);
}
.topbar{
  display:flex;
  gap:16px;
  align-items:center;
  justify-content:space-between;
  padding:12px 14px;
  border-bottom:1px solid var(--line);
  position:sticky;
  top:0;
  background:rgba(11,18,32,.92);
  backdrop-filter: blur(6px);
  z-index:10;
}
.brand{display:flex; gap:10px; align-items:center}
.brand .dot{
  width:12px;height:12px;border-radius:50%;
  background:linear-gradient(180deg, #3ee28a, #1ea8ff);
  box-shadow:0 0 16px rgba(62,226,138,.35);
}
.title{font-weight:800; letter-spacing:.2px}
.subtitle{color:var(--muted); font-size:12px; margin-top:2px}

.controls{display:flex; gap:10px; align-items:end; flex-wrap:wrap}
label{display:flex; flex-direction:column; gap:4px; font-size:12px; color:var(--muted)}
input, select{
  background:#0d162a;
  border:1px solid var(--line);
  color:var(--text);
  padding:8px 9px;
  border-radius:10px;
  outline:none;
}
input::placeholder{color:#62739a}
.btn{
  background:linear-gradient(180deg, var(--btn2), var(--btn));
  border:1px solid var(--line);
  color:var(--text);
  padding:9px 12px;
  border-radius:12px;
  cursor:pointer;
}
.btn:disabled{opacity:.45; cursor:not-allowed}

@media (max-width: 1100px){
  .layout{grid-template-columns:1fr}
}
.card{
  background:rgba(17,26,46,.85);
  border:1px solid var(--line);
  border-radius:16px;
  padding:12px;
  box-shadow:0 10px 30px rgba(0,0,0,.25);
}
.cardTitle{font-weight:800; margin-bottom:10px}
.cardTitle.row{display:flex; justify-content:space-between; align-items:center}
.hint{color:var(--muted); font-weight:600; font-size:12px}

.list{display:flex; flex-direction:column; gap:8px}

.item{
  border:1px solid var(--line);
  border-radius:14px;
  padding:10px;
  background:rgba(13,22,42,.75);
  display:flex;
  gap:10px;
  align-items:flex-start;
  justify-content:space-between;
}
.item:hover{border-color:#35508a}
.item.prio-red{border-left:6px solid var(--danger)}
.item.prio-yellow{border-left:6px solid var(--warn)}
.item.prio-green{border-left:6px solid var(--ok)}
.item.prio-white{border-left:6px solid var(--white)}
.itemMain{display:flex; gap:10px; align-items:flex-start}
.bullet{
  width:12px;height:12px;border-radius:50%;
  margin-top:4px;
}
.street{font-weight:800}
.desc{color:var(--muted); font-size:12px; margin-top:2px}
.badges{display:flex; gap:6px; margin-top:6px; flex-wrap:wrap}
.badge{
  font-size:11px;
  padding:4px 8px;
  border-radius:999px;
  border:1px solid var(--line);
  color:var(--muted);
}
.badge.strong{color:var(--text)}
.actions{display:flex; flex-direction:column; gap:6px; align-items:end}
.smallbtn{
  background:#0d162a;
  border:1px solid var(--line);
  color:var(--text);
  padding:7px 10px;
  border-radius:12px;
  cursor:pointer;
  font-size:12px;
}
.smallbtn:disabled{opacity:.45; cursor:not-allowed}

.activeTask{
  padding:10px;
  border:1px dashed #365089;
  border-radius:14px;
  color:var(--muted);
}
.activeTask strong{color:var(--text)}

.mapCard{padding-bottom:10px}
#map{
  width:100%;
  height: 360px;
  border-radius:14px;
  border:1px solid var(--line);
  overflow:hidden;
}
.mapHint{color:var(--muted); font-size:12px; margin-top:8px}

.detail{color:var(--muted); line-height:1.45}
.detail .row{display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin:8px 0}
.detail .pill{padding:4px 8px; border-radius:999px; border:1px solid var(--line); font-size:12px}
.detail .btnRow{display:flex; gap:8px; flex-wrap:wrap; margin-top:10px}
.sep{height:1px; background:var(--line); margin:10px 0}


.legend{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  margin-top:10px;
  color:var(--muted);
  font-size:12px;
}
.legendItem{
  display:flex;
  align-items:center;
  gap:6px;
  padding:6px 8px;
  border:1px solid var(--line);
  border-radius:999px;
  background:rgba(13,22,42,.55);
}
.legendDot{
  width:10px;height:10px;border-radius:50%;
}
.hidden{display:none !important;}


.plannerGrid{
  display:grid;
  grid-template-columns: 1fr 1.2fr;
  gap:12px;
}
@media (max-width: 1200px){
  .plannerGrid{grid-template-columns:1fr}
}

.subTitle{font-weight:800; margin:6px 0 8px 0}
.attendance{display:flex; flex-direction:column; gap:6px; max-height:420px; overflow:auto; padding-right:6px}
.attRow{
  display:flex; align-items:center; justify-content:space-between;
  gap:8px;
  padding:8px 10px;
  border:1px solid var(--line);
  border-radius:12px;
  background:rgba(13,22,42,.55);
}
.attRow label{flex-direction:row; align-items:center; gap:8px; color:var(--text); font-size:13px}
.attRow .mut{color:var(--muted); font-size:12px; display:flex; flex-direction:column; align-items:flex-end; gap:6px}

.teams{display:flex; flex-direction:column; gap:10px; max-height:420px; overflow:auto; padding-right:6px}
.teamBox{
  border:1px solid var(--line);
  border-radius:14px;
  background:rgba(13,22,42,.55);
  padding:10px;
}
.teamHeader{display:flex; justify-content:space-between; align-items:center; gap:10px; margin-bottom:8px}
.teamHeader strong{font-size:14px}
.teamHeader .meta{color:var(--muted); font-size:12px}
.teamBody{display:flex; flex-direction:column; gap:8px}
.pills{display:flex; gap:6px; flex-wrap:wrap}
.pillBtn{
  border:1px solid var(--line);
  background:#0d162a;
  color:var(--text);
  border-radius:999px;
  padding:6px 10px;
  cursor:pointer;
  font-size:12px;
}
.pillBtn:hover{border-color:#35508a}
.pillBtn .x{opacity:.6;margin-left:6px}
.teamControls{display:grid; grid-template-columns:1fr auto; gap:8px}
.teamControls select{width:100%}
.teamControls .smallbtn{width:100%}

.vehiclePick{display:grid; grid-template-columns:1fr 1fr; gap:8px}
.vehicleList{display:flex; flex-direction:column; gap:8px}
.vehicleItem{
  display:flex; justify-content:space-between; align-items:center; gap:10px;
  padding:8px 10px;
  border:1px solid var(--line);
  border-radius:12px;
  background:rgba(13,22,42,.55);
}


.mapCollapsed #map{height:0 !important; padding:0 !important; margin:0 !important; border:0 !important;}
.mapCollapsed .mapHint, .mapCollapsed .legend{display:none !important;}

.btn.small{padding:6px 10px; font-size:12px}

@media (max-width: 820px){
  .newTaskRow{grid-template-columns:1fr;}
  .newTaskRow button{width:100%;}
}

.left, .right{
  display:flex;
  flex-direction:column;
  gap:14px;
  min-height: calc(100vh - 70px);
}

.controls label{min-width:120px}

#mapCard.mapCollapsed #map{height:0 !important; border:0 !important;}
#mapCard.mapCollapsed .mapHint, #mapCard.mapCollapsed .legend{display:none !important;}

.newTaskRow{
  display:grid;
  grid-template-columns: 1fr 1fr;
  gap:10px;
}
#newPrio{grid-column:1 / 2}
#addTask{grid-column:2 / 3}
#newStreet{grid-column:1 / 3}
#newDesc{grid-column:1 / 3}
@media (max-width: 820px){
  .layout{grid-template-columns:1fr;}
  .newTaskRow{grid-template-columns:1fr;}
  #addTask,#newPrio,#newStreet,#newDesc{grid-column:auto;}
}

@media (max-width: 1100px){#mapCard{width:100%;}}

/* --- Resizable 3-pane layout (v10) --- */
:root{
  --w-left: 420px;
  --w-map: 520px;
}

.layout3{
  display:flex;
  gap:0;
  padding:14px;
  height: calc(100vh - 78px);
  box-sizing:border-box;
}

.pane{
  overflow:auto;
  min-width: 280px;
  padding-right: 10px;
}

.leftPane{flex: 0 0 var(--w-left);}
.mapPane{flex: 0 0 var(--w-map);}
.detailPane{flex: 1 1 auto; min-width: 320px;}

.splitterV{
  width:10px;
  cursor: col-resize;
  border-radius:999px;
  margin:0 6px;
  background: rgba(255,255,255,0.06);
  border:1px solid rgba(255,255,255,0.07);
  align-self:stretch;
}
.splitterV:hover{background: rgba(255,255,255,0.10);}
.splitterV.dragging{background: rgba(255,255,255,0.14);}

#map{
  width:100%;
  height:360px;
  border-radius:16px;
  overflow:hidden;
}

@media (max-width: 1100px){
  .layout3{flex-direction:column; height:auto;}
  .splitterV{display:none;}
  .leftPane,.mapPane,.detailPane{flex: 0 0 auto; min-width: unset; padding-right:0;}
  #map{height:420px;}
}

/* Make selects/buttons behave in narrow cards */
select, input{max-width:100%;}

/* --- Widget board layout (v12) --- */
.board{
  padding:14px;
  height: calc(100vh - 78px);
  box-sizing:border-box;
  overflow:hidden;
}
.boardTop{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:12px;
  margin-bottom:10px;
}
.columns{
  display:grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap:12px;
  height: calc(100% - 44px);
}
.column{
  overflow:auto;
  padding-right:6px;
  border-radius:16px;
}
.widget{
  margin-bottom:12px;
  position:relative;
}
.dragHandle{
  user-select:none;
  cursor:grab;
  opacity:.7;
  font-weight:900;
  letter-spacing:2px;
}
.dragHandle:active{cursor:grabbing;}
.widget.dragging{opacity:.55; outline:2px dashed rgba(255,255,255,.25);}

/* Widget resize handle (PC) */
.resizeHandle{
  position:absolute;
  right:10px;
  bottom:10px;
  width:14px;
  height:14px;
  cursor:nwse-resize;
  opacity:.55;
  border-radius:4px;
  background:
    linear-gradient(135deg, transparent 0 50%, rgba(255,255,255,.35) 50% 55%, transparent 55% 65%, rgba(255,255,255,.35) 65% 70%, transparent 70% 80%, rgba(255,255,255,.35) 80% 85%, transparent 85% 100%);
}
.resizeHandle:hover{opacity:.85;}
.widget.resizing{outline:2px solid rgba(255,255,255,.18);}

#map{
  width:100%;
  height: 360px; /* dubbele hoogte */
  border-radius:16px;
  overflow:hidden;
}

@media (max-width: 1100px){
  .columns{grid-template-columns:1fr; height:auto;}
  .board{height:auto; overflow:visible;}
  #map{height:420px;}
}

/* --- Startup splash (logo) --- */
.splash{
  position:fixed;
  inset:0;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:22px;
  background: radial-gradient(900px 700px at 20% 10%, #162447 0%, var(--bg) 70%);
  z-index:9999;
}
.splash .box{
  width:min(520px, 100%);
  border:1px solid rgba(255,255,255,.10);
  border-radius:20px;
  background:rgba(17,26,46,.70);
  box-shadow:0 18px 44px rgba(0,0,0,.38);
  padding:18px 18px 16px 18px;
  text-align:center;
}
.splash .logo{
  width:96px;
  height:96px;
  display:block;
  margin:4px auto 10px auto;
}
.splash .t1{ font-weight:900; letter-spacing:.3px; }
.splash .t2{ color:var(--muted); font-size:12px; margin-top:4px; }
.splash.hide{ opacity:0; pointer-events:none; transition: opacity .25s ease; }

.tinybtn{border:1px solid rgba(255,255,255,0.18);background:rgba(255,255,255,0.06);color:var(--text);padding:6px 10px;border-radius:12px;font-size:12px;font-weight:800;cursor:pointer}
.tinybtn:active{transform:scale(0.98)}


/* Admin floating widgets: same style, just standalone and moveable */
#employeeAdminCard .vehicleList,
#deviceLinksCard .vehicleList,
#foremanAdminCard .vehicleList{
  min-height: 96px;
}
